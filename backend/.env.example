# ─────────────────────────────────────────────────
#  Agentra MailSense – Environment Variables
# ─────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Google OAuth2 – get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth2callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/google-callback

# App URL (used for OAuth redirect)
APP_URL=http://localhost:3000

# Email (for OTP sending) – use Gmail App Password or any SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=Agentra MailSense <your_sender_email@gmail.com>

# Mistral AI – get free API key at https://console.mistral.ai
# Models: mistral-small-latest | mistral-medium-latest | mistral-large-latest
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# SQLite DB path
DB_PATH=./mailsense.db
