{
  "version": 2,
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/login", "destination": "/api/login.js" },
    { "source": "/api/signup-send-otp", "destination": "/api/signup-send-otp.js" },
    { "source": "/api/signup-verify-otp", "destination": "/api/signup-verify-otp.js" },
    { "source": "/api/forgot-send-otp", "destination": "/api/forgot-send-otp.js" },
    { "source": "/api/forgot-verify-otp", "destination": "/api/forgot-verify-otp.js" },
    { "source": "/api/forgot-reset-password", "destination": "/api/forgot-reset-password.js" },
    { "source": "/api/delete-account", "destination": "/api/delete-account.js" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}